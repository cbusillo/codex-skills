#!/usr/bin/env bash
set -euo pipefail

script_dir="$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)"
gh_bin="${GH_ISSUE_GH:-$script_dir/gh-with-env-token}"

usage() {
	cat <<'USAGE'
Usage:
  gh-issue create TITLE [--repo OWNER/REPO] [gh issue create options]
  gh-issue edit NUMBER [--repo OWNER/REPO] [gh issue edit options]
  gh-issue close NUMBER [--repo OWNER/REPO] [gh issue close options]

Read a GitHub issue body from stdin and pass it to gh with --body-file,
preserving literal Markdown backticks, newlines, and shell-looking text.

For close, stdin is passed to gh issue close as the closing comment.
Large close comments are posted with gh issue comment --body-file before the
issue is closed, because gh issue close does not support --body-file.
USAGE
}

if [[ $# -lt 2 ]]; then
	usage >&2
	exit 2
fi

command="$1"
target="$2"
shift 2

case "$command" in
create | edit | close) ;;
*)
	echo "error: first argument must be 'create', 'edit', or 'close'" >&2
	usage >&2
	exit 2
	;;
esac

tmp_body="$(mktemp)"
cleanup() {
	rm -f "$tmp_body"
}
trap cleanup EXIT

cat >"$tmp_body"

if [[ ! -s "$tmp_body" ]]; then
	echo "error: issue body is empty" >&2
	exit 2
fi

case "$command" in
create)
	"$gh_bin" issue create --title "$target" --body-file "$tmp_body" "$@"
	;;
edit)
	"$gh_bin" issue edit "$target" --body-file "$tmp_body" "$@"
	;;
close)
	close_args=()
	comment_args=()
	remaining=("$@")
	idx=0
	while [[ "$idx" -lt "${#remaining[@]}" ]]; do
		arg="${remaining[$idx]}"
		case "$arg" in
		--repo | -R)
			if [[ "$((idx + 1))" -ge "${#remaining[@]}" ]]; then
				echo "error: $arg requires a value" >&2
				exit 2
			fi
			close_args+=("$arg" "${remaining[$((idx + 1))]}")
			comment_args+=("$arg" "${remaining[$((idx + 1))]}")
			idx=$((idx + 2))
			;;
		--repo=*)
			close_args+=("$arg")
			comment_args+=("$arg")
			idx=$((idx + 1))
			;;
		-R*)
			close_args+=("$arg")
			comment_args+=("$arg")
			idx=$((idx + 1))
			;;
		--comment | -c)
			if [[ "$((idx + 1))" -ge "${#remaining[@]}" ]]; then
				echo "error: $arg requires a value" >&2
				exit 2
			fi
			idx=$((idx + 2))
			;;
		--comment=* | -c*)
			idx=$((idx + 1))
			;;
		*)
			close_args+=("$arg")
			idx=$((idx + 1))
			;;
		esac
	done
	comment_arg_max="${GH_ISSUE_CLOSE_COMMENT_ARG_MAX:-32768}"
	if [[ ! "$comment_arg_max" =~ ^[0-9]+$ ]]; then
		echo "error: GH_ISSUE_CLOSE_COMMENT_ARG_MAX must be a non-negative integer" >&2
		exit 2
	fi
	body_size="$(wc -c <"$tmp_body" | tr -d '[:space:]')"
	if [[ "$body_size" -le "$comment_arg_max" ]]; then
		"$gh_bin" issue close "$target" --comment "$(<"$tmp_body")" "${close_args[@]}"
	else
		"$gh_bin" issue comment "$target" --body-file "$tmp_body" "${comment_args[@]}"
		"$gh_bin" issue close "$target" "${close_args[@]}"
	fi
	;;
esac
