#!/usr/bin/env bash
set -euo pipefail

script_dir="$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)"
gh_bin="${GH_ISSUE_GH:-$script_dir/gh-with-env-token}"

usage() {
	cat <<'USAGE'
Usage:
  gh-issue create TITLE [--repo OWNER/REPO] [gh issue create options]
  gh-issue edit NUMBER [--repo OWNER/REPO] [gh issue edit options]

Read a GitHub issue body from stdin and pass it to gh with --body-file,
preserving literal Markdown backticks, newlines, and shell-looking text.
USAGE
}

if [[ $# -lt 2 ]]; then
	usage >&2
	exit 2
fi

command="$1"
target="$2"
shift 2

case "$command" in
create | edit) ;;
*)
	echo "error: first argument must be 'create' or 'edit'" >&2
	usage >&2
	exit 2
	;;
esac

tmp_body="$(mktemp)"
cleanup() {
	rm -f "$tmp_body"
}
trap cleanup EXIT

cat >"$tmp_body"

if [[ ! -s "$tmp_body" ]]; then
	echo "error: issue body is empty" >&2
	exit 2
fi

is_rate_limited() {
	grep -Eiq 'rate limit|rate_limit|API rate limit|secondary rate' "$1"
}

run_gh_issue() {
	local stderr_file
	local status=0
	stderr_file="$(mktemp)"
	case "$command" in
	create)
		"$gh_bin" issue create --title "$target" --body-file "$tmp_body" "$@" 2>"$stderr_file" || status=$?
		;;
	edit)
		"$gh_bin" issue edit "$target" --body-file "$tmp_body" "$@" 2>"$stderr_file" || status=$?
		;;
	esac
	status="${status:-0}"
	if [[ $status -eq 0 ]]; then
		rm -f "$stderr_file"
		return 0
	fi
	if [[ -z "${GH_ISSUE_GH:-}" && "$gh_bin" != "gh" ]] && is_rate_limited "$stderr_file"; then
		cat "$stderr_file" >&2
		echo "warning: automation gh token hit a rate limit; retrying with active gh auth" >&2
		case "$command" in
		create)
			gh issue create --title "$target" --body-file "$tmp_body" "$@"
			;;
		edit)
			gh issue edit "$target" --body-file "$tmp_body" "$@"
			;;
		esac
		status=$?
	else
		cat "$stderr_file" >&2
	fi
	rm -f "$stderr_file"
	return "$status"
}

run_gh_issue "$@"
