#!/bin/sh
set -eu

script_dir=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)

if [ -n "${GH_ISSUE_PYTHON:-}" ]; then
	exec "$GH_ISSUE_PYTHON" "$script_dir/github_issue.py" "$@"
fi
if ! command -v uv >/dev/null 2>&1; then
	printf 'error: gh-issue requires uv or GH_ISSUE_PYTHON\n' >&2
	exit 127
fi
exec uv run --no-project --no-config --python 3.12 python "$script_dir/github_issue.py" "$@"
