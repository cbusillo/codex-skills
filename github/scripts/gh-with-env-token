#!/bin/sh
set -eu

script_dir=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
classifier=${GH_WITH_ENV_TOKEN_CLASSIFIER:-$script_dir/github_api.py}
python_command=${GH_WITH_ENV_TOKEN_PYTHON:-python3}

if [ -n "${CODEX_SKILLS_ENV_FILE:-}" ]; then
	env_file=$CODEX_SKILLS_ENV_FILE
elif [ -n "${CODE_HOME:-}" ]; then
	env_file=$CODE_HOME/local.env
elif [ -n "${CODEX_HOME:-}" ]; then
	env_file=$CODEX_HOME/local.env
elif [ -n "${HOME:-}" ]; then
	env_file=$HOME/.code/local.env
else
	env_file=
fi
gh_command=${GH_WITH_ENV_TOKEN_GH:-gh}
expected_login=${GH_WITH_ENV_TOKEN_EXPECTED_LOGIN:-shiny-code-bot}
print_auth_account=0
require_automation_auth=0
stdout_file=$(mktemp)
stderr_file=$(mktemp)
classification_file=$(mktemp)
stdin_file=$(mktemp)
stdin_captured=0

trap 'rm -f "$stdout_file" "$stderr_file" "$classification_file" "$stdin_file"' EXIT INT HUP TERM

case "${GH_WITH_ENV_TOKEN_REQUIRE_AUTOMATION_AUTH:-}" in
1 | true | TRUE | yes | YES)
	require_automation_auth=1
	;;
esac

while [ "$#" -gt 0 ]; do
	case "${1:-}" in
	--print-auth-account)
		print_auth_account=1
		shift
		;;
	--require-automation-auth)
		require_automation_auth=1
		shift
		;;
	*)
		break
		;;
	esac
done
readonly require_automation_auth

if [ -f "$env_file" ]; then
	set -a
	# shellcheck disable=SC1090
	. "$env_file"
	set +a
fi

if [ -n "${CODEX_GITHUB_TOKEN:-}" ]; then
	GH_TOKEN=$CODEX_GITHUB_TOKEN
elif [ -z "${GH_TOKEN:-}" ] && [ -n "${GITHUB_TOKEN:-}" ]; then
	GH_TOKEN=$GITHUB_TOKEN
fi

if [ ! -t 0 ]; then
	cat >"$stdin_file"
	stdin_captured=1
fi

run_with_input() {
	if [ "$stdin_captured" -eq 1 ]; then
		"$@" <"$stdin_file"
	else
		"$@"
	fi
}

allows_active_auth_fallback() {
	if [ "$require_automation_auth" -eq 1 ]; then
		return 1
	fi
	case "${GH_WITH_ENV_TOKEN_ALLOW_ACTIVE_AUTH_FALLBACK:-}" in
	1 | true | TRUE | yes | YES)
		return 0
		;;
	*)
		return 1
		;;
	esac
}

is_write_command() {
	while [ "$#" -gt 0 ]; do
		case "${1:-}" in
		-R | --repo | --hostname)
			shift 2 || return 1
			;;
		--repo=* | --hostname=*)
			shift
			;;
		--)
			shift
			break
			;;
		-*)
			shift
			;;
		*)
			break
			;;
		esac
	done

	case "${1:-}" in
	api)
		shift
		while [ "$#" -gt 0 ]; do
			case "$1" in
			--method | -X)
				case "${2:-}" in
				GET | get | HEAD | head)
					return 1
					;;
				*)
					return 0
					;;
				esac
				;;
			--method=* | -X*)
				method=${1#*=}
				if [ "$method" = "$1" ]; then
					method=${1#-X}
				fi
				case "$method" in
				GET | get | HEAD | head)
					return 1
					;;
				*)
					return 0
					;;
				esac
				;;
			-f | -F | --field | --raw-field | --input)
				return 0
				;;
			--field=* | --raw-field=* | --input=*)
				return 0
				;;
			esac
			shift
		done
		return 1
		;;
	issue)
		case "${2:-}" in
		create | edit | close | comment | delete | develop | transfer | pin | unpin | lock | unlock | reopen)
			return 0
			;;
		esac
		;;
	pr)
		case "${2:-}" in
		assign | close | comment | convert-to-draft | create | edit | label | lock | merge | ready | reopen | request-review | review | unlock | update-branch)
			return 0
			;;
		esac
		;;
	run)
		case "${2:-}" in
		approve | cancel | delete | rerun)
			return 0
			;;
		esac
		;;
	workflow)
		case "${2:-}" in
		disable | enable | run)
			return 0
			;;
		esac
		;;
	release)
		case "${2:-}" in
		create | upload | edit | delete | delete-asset)
			return 0
			;;
		esac
		;;
	repo)
		case "${2:-}" in
		create | edit | delete | archive | unarchive | fork | deploy-key | autolink | sync)
			return 0
			;;
		esac
		;;
	project)
		case "${2:-}" in
		create | edit | delete | close | reopen | item-add | item-archive | item-create | item-delete | item-edit)
			return 0
			;;
		esac
		;;
	label)
		case "${2:-}" in
		create | edit | delete | clone)
			return 0
			;;
		esac
		;;
	secret | variable)
		case "${2:-}" in
		set | delete)
			return 0
			;;
		esac
		;;
	gist)
		case "${2:-}" in
		create | edit | delete)
			return 0
			;;
		esac
		;;
	*)
		;;
	esac
	return 1
}

validate_sensitive_read_policy() {
	"$python_command" - "$require_automation_auth" "$@" <<'PY'
import re
import sys
import urllib.parse

require_automation_auth = sys.argv[1] == "1"
arguments = sys.argv[2:]


def decoded_path(value: str) -> str:
    parsed = urllib.parse.urlsplit(value)
    path = parsed.path
    while True:
        decoded = urllib.parse.unquote(path)
        if decoded == path:
            break
        path = decoded
    return f"/{path.lstrip('/')}"


def is_sensitive_endpoint(value: str) -> bool:
    return bool(
        re.fullmatch(
            r"/repos/[^/]+/[^/]+/secret-scanning/alerts(?:/.*)?",
            decoded_path(value),
        )
    )


def reject() -> None:
    print("error: raw repository secret-scanning alert operations are disabled", file=sys.stderr)
    print(
        "hint: use github/scripts/github_read.py --repo OWNER/REPO secret-scanning-status for reads",
        file=sys.stderr,
    )
    raise SystemExit(1)


try:
    api_index = arguments.index("api")
except ValueError:
    raise SystemExit(0)

api_arguments = arguments[api_index + 1 :]
endpoints = [argument for argument in api_arguments if is_sensitive_endpoint(argument)]
if not endpoints:
    raise SystemExit(0)
if len(endpoints) != 1 or not require_automation_auth:
    reject()

endpoint = endpoints[0]
methods = []
headers = []
include_count = 0
endpoint_count = 0
invalid_argument = False
index = 0
while index < len(api_arguments):
    argument = api_arguments[index]
    if argument == endpoint:
        endpoint_count += 1
        index += 1
    elif argument in {"--method", "-X"}:
        if index + 1 >= len(api_arguments):
            invalid_argument = True
            break
        methods.append(api_arguments[index + 1].upper())
        index += 2
    elif argument.startswith("--method="):
        methods.append(argument.split("=", 1)[1].upper())
        index += 1
    elif argument.startswith("-X") and argument != "-X":
        methods.append(argument[2:].upper())
        index += 1
    elif argument in {"--include", "-i"}:
        include_count += 1
        index += 1
    elif argument in {"--header", "-H"}:
        if index + 1 >= len(api_arguments):
            invalid_argument = True
            break
        headers.append(api_arguments[index + 1])
        index += 2
    elif argument.startswith("--header="):
        headers.append(argument.split("=", 1)[1])
        index += 1
    elif argument.startswith("-H") and argument != "-H":
        headers.append(argument[2:])
        index += 1
    else:
        invalid_argument = True
        index += 1

parsed_endpoint = urllib.parse.urlsplit(endpoint)
query = urllib.parse.parse_qs(parsed_endpoint.query, keep_blank_values=True)
header_name, header_separator, header_value = headers[0].partition(":") if len(headers) == 1 else ("", "", "")
allowed_header = (
    header_name.strip().casefold() == "x-github-api-version"
    and header_separator == ":"
    and header_value.strip() == "2022-11-28"
)
allowed_query_keys = {"state", "hide_secret", "per_page", "page"}
per_page_values = query.get("per_page", [])
page_values = query.get("page", [])
valid_per_page = not per_page_values or (
    len(per_page_values) == 1
    and per_page_values[0].isdigit()
    and 1 <= int(per_page_values[0]) <= 100
)
valid_page = not page_values or (
    len(page_values) == 1
    and page_values[0].isdigit()
    and int(page_values[0]) >= 1
)
is_collection = bool(
    re.fullmatch(
        r"/repos/[^/]+/[^/]+/secret-scanning/alerts",
        decoded_path(endpoint),
    )
)
if (
    invalid_argument
    or endpoint_count != 1
    or methods != ["GET"]
    or include_count != 1
    or len(headers) != 1
    or not allowed_header
    or not is_collection
    or parsed_endpoint.fragment
    or not set(query).issubset(allowed_query_keys)
    or query.get("state") != ["open"]
    or query.get("hide_secret") != ["true"]
    or not valid_per_page
    or not valid_page
):
    reject()
PY
}

active_auth_login() {
	env -u GH_TOKEN -u GITHUB_TOKEN -u CODEX_GITHUB_TOKEN "$gh_command" api user --jq .login 2>/dev/null || true
}

verify_bot_login_for_write() {
	if ! is_write_command "$@"; then
		return 0
	fi
	login_status=0
	"$python_command" "$classifier" --gh "$gh_command" call \
		--method GET \
		--read \
		--operation github.auth.verify_actor \
		/user >"$classification_file" 2>"$stderr_file" || login_status=$?
	if [ "$login_status" -ne 0 ]; then
		print_classified_message
		echo "error: unable to verify the automation GitHub actor; refusing write" >&2
		return "$login_status"
	fi
	login=$(classified_value login "" 2>/dev/null) || login=
	if [ "$login" = "$expected_login" ]; then
		return 0
	fi
	echo "error: GitHub write would run as '${login:-unknown}', expected '$expected_login'" >&2
	echo "hint: configure CODEX_GITHUB_TOKEN for $expected_login before writing to GitHub" >&2
	return 1
}

refuse_active_auth_fallback() {
	reason=$1
	if allows_active_auth_fallback; then
		return 1
	fi
	echo "error: $reason; refusing to use active local gh auth" >&2
	if [ "$require_automation_auth" -eq 1 ]; then
		echo "hint: this command requires configured automation authentication" >&2
	else
		echo "hint: configure CODEX_GITHUB_TOKEN for shiny-code-bot, or set GH_WITH_ENV_TOKEN_ALLOW_ACTIVE_AUTH_FALLBACK=1 for an explicitly approved one-off" >&2
	fi
	return 0
}

classify_failure() {
	status_code=$1
	shift
	write_flag=
	if is_write_command "$@"; then
		write_flag=--write
	fi
	"$python_command" "$classifier" --gh "$gh_command" classify-legacy \
		--returncode "$status_code" \
		--stdout-file "$stdout_file" \
		--stderr-file "$stderr_file" \
		--operation github.gh_with_env_token \
		--expected-actor "$expected_login" \
		--transport gh_cli_wrapper \
		--probe-unknown-rate-limit \
		$write_flag >"$classification_file" 2>/dev/null
}

classified_value() {
	field=$1
	default_value=$2
	"$python_command" - "$classification_file" "$field" "$default_value" <<'PY'
import json
import pathlib
import sys

payload = json.loads(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8"))
field = sys.argv[2]
default = sys.argv[3]
failure = payload.get("failure") or {}
if field == "cause":
    value = payload.get("error_code") or failure.get("cause")
elif field == "message":
    value = failure.get("message") or payload.get("error")
elif field == "login":
    body = payload.get("body") or {}
    value = body.get("login") if isinstance(body, dict) else None
else:
    value = payload.get(field)
print(default if value is None else value)
PY
}

print_classified_message() {
	message=$(classified_value message "GitHub command failed" 2>/dev/null) || message="GitHub command failed"
	printf '%s\n' "$message" >&2
}

retry_with_active_auth() {
	reason=$1
	shift
	print_classified_message
	fallback_login=$(active_auth_login)
	echo "warning: $reason; explicitly authorized active-auth fallback; retrying with the active gh account '${fallback_login:-unknown}'" >&2
	if [ "$print_auth_account" -eq 1 ]; then
		env -u GH_TOKEN -u GITHUB_TOKEN -u CODEX_GITHUB_TOKEN "$gh_command" auth status >&2 || true
	fi
	run_with_input env -u GH_TOKEN -u GITHUB_TOKEN -u CODEX_GITHUB_TOKEN "$gh_command" "$@"
}

print_account() {
	label=$1
	echo "gh auth status ($label):" >&2
	"$gh_command" auth status >&2 || true
}

if ! validate_sensitive_read_policy "$@"; then
	exit 2
fi

if [ -z "${GH_TOKEN:-}" ]; then
	if refuse_active_auth_fallback "no automation gh token found"; then
		exit 1
	fi
	fallback_login=$(active_auth_login)
	echo "warning: no automation gh token found; explicitly authorized active-auth fallback; using the active gh account '${fallback_login:-unknown}'" >&2
	if [ "$print_auth_account" -eq 1 ]; then
		echo "gh auth status (active gh auth):" >&2
		env -u GH_TOKEN -u GITHUB_TOKEN -u CODEX_GITHUB_TOKEN "$gh_command" auth status >&2 || true
	fi
	run_with_input env -u GH_TOKEN -u GITHUB_TOKEN -u CODEX_GITHUB_TOKEN "$gh_command" "$@"
	exit $?
fi

export GH_TOKEN

if [ "$print_auth_account" -eq 1 ]; then
	print_account "automation token"
fi

verify_bot_login_for_write "$@"

status=0
run_with_input "$gh_command" "$@" >"$stdout_file" 2>"$stderr_file" || status=$?
if [ "$status" -eq 0 ]; then
	cat "$stdout_file"
	exit 0
fi

cause=unknown_error
if classify_failure "$status" "$@"; then
	:
fi
if [ -s "$classification_file" ]; then
	cause=$(classified_value cause unknown_error 2>/dev/null) || cause=unknown_error
fi
write_outcome=$(classified_value write_outcome "" 2>/dev/null) || write_outcome=

if is_write_command "$@" && [ "$write_outcome" = "unknown" ]; then
	cat "$stdout_file"
	print_classified_message
	echo "error: automation GitHub write outcome is unknown; refusing active-auth replay" >&2
	exit "$status"
fi

case "$cause" in
graphql_primary_rate_limited | rest_primary_rate_limited | secondary_rate_limited | rate_limited_unknown_bucket)
	if refuse_active_auth_fallback "automation gh request was rate-limited"; then
		cat "$stdout_file"
		print_classified_message
		exit "$status"
	fi
	retry_with_active_auth "automation gh request was rate-limited" "$@"
	exit $?
	;;
invalid_credentials)
	if refuse_active_auth_fallback "automation gh authentication failed"; then
		cat "$stdout_file"
		print_classified_message
		exit "$status"
	fi
	retry_with_active_auth "automation gh authentication failed" "$@"
	exit $?
	;;
esac

cat "$stdout_file"
print_classified_message
exit "$status"
