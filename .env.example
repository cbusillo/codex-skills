# Optional GitHub automation token for scripts/gh-with-env-token.
#
# Copy this file to $CODE_HOME/local.env, $CODEX_HOME/local.env, or
# ~/.code/local.env and set one of these variables. The local.env file is
# machine-local and must not be committed.

# Preferred for GitHub CLI automation.
# GH_TOKEN=github_pat_xxx

# Also accepted; the wrapper exports it as GH_TOKEN for gh.
# GITHUB_TOKEN=github_pat_xxx

# Backward-compatible local alias for existing private setups.
# CODEX_GITHUB_TOKEN=github_pat_xxx

# Protected workflow review uses the active local `gh` account as the human
# reviewer. Do not put the human token in this file; authenticate it with
# `gh auth login` and keep it distinct from the automation account above.
