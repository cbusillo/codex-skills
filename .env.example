# Optional GitHub automation token for scripts/gh-with-env-token.
#
# Copy this file to .env and set one of these variables. The .env file is
# ignored by git.

# Preferred for GitHub CLI automation.
# GH_TOKEN=github_pat_xxx

# Also accepted; the wrapper exports it as GH_TOKEN for gh.
# GITHUB_TOKEN=github_pat_xxx

# Backward-compatible local alias for existing private setups.
# CODEX_GITHUB_TOKEN=github_pat_xxx
