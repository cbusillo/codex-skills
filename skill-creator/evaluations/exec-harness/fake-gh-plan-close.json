{
  "name": "fake-gh-plan-close",
  "model": "gpt-5.1-codex",
  "prompt": "Close completed durable planning issue #900 through the GitHub planning helper using the provided close-comment.md file.",
  "files": {
    "README.md": "# Fake gh planning close fixture\n",
    "close-comment.md": "Completed with validation evidence.\n",
    ".github/github.json": "{\"planning\":{\"projects\":{\"enabled\":false}}}\n"
  },
  "gh": {
    "repo": "cbusillo/codex-skills",
    "issues": [
      {
        "number": 900,
        "title": "Completed plan",
        "body": "## Finish Line\nShip the completed plan.\n",
        "labels": [{ "name": "plan" }, { "name": "plan:active" }],
        "state": "open",
        "html_url": "https://github.com/cbusillo/codex-skills/issues/900",
        "url": "https://github.com/cbusillo/codex-skills/issues/900"
      }
    ],
    "responses": [
      {
        "match": {
          "contains": ["api", "/user"]
        },
        "stdout": "{\"login\":\"shiny-code-bot\"}"
      },
      {
        "match": {
          "contains": ["api", "repos/cbusillo/codex-skills/issues/900/dependencies/blocked_by?per_page=100&page=1"]
        },
        "stdout": "[]"
      },
      {
        "match": {
          "contains": ["api", "repos/cbusillo/codex-skills/issues/900/sub_issues?per_page=100&page=1"]
        },
        "stdout": "[]"
      },
      {
        "match": {
          "contains": ["api", "repos/cbusillo/codex-skills/issues/900"]
        },
        "stdout": "{\"number\":900,\"title\":\"Completed plan\",\"body\":\"## Finish Line\\nShip the completed plan.\\n\",\"labels\":[{\"name\":\"plan\"},{\"name\":\"plan:active\"}],\"state\":\"open\",\"state_reason\":null,\"html_url\":\"https://github.com/cbusillo/codex-skills/issues/900\"}"
      },
      {
        "match": {
          "contains": ["api", "--method", "POST", "/repos/cbusillo/codex-skills/issues/900/labels"]
        },
        "stdout": "[{\"name\":\"plan\"},{\"name\":\"plan:active\"},{\"name\":\"plan:done\"}]"
      },
      {
        "match": {
          "contains": ["api", "--method", "DELETE", "/repos/cbusillo/codex-skills/issues/900/labels/plan%3Aactive"]
        },
        "stdout": "[{\"name\":\"plan\"},{\"name\":\"plan:done\"}]"
      },
      {
        "match": {
          "contains": ["api", "--method", "POST", "/repos/cbusillo/codex-skills/issues/900/comments"]
        },
        "stdout": "{\"id\":9001,\"html_url\":\"https://github.com/cbusillo/codex-skills/issues/900#issuecomment-9001\",\"user\":{\"login\":\"shiny-code-bot\"}}"
      },
      {
        "match": {
          "contains": ["api", "--method", "PATCH", "/repos/cbusillo/codex-skills/issues/900"]
        },
        "stdout": "{\"number\":900,\"title\":\"Completed plan\",\"body\":\"## Finish Line\\nShip the completed plan.\\n\",\"labels\":[{\"name\":\"plan\"},{\"name\":\"plan:active\"}],\"state\":\"closed\",\"state_reason\":\"completed\",\"html_url\":\"https://github.com/cbusillo/codex-skills/issues/900\"}"
      }
    ]
  },
  "responses_api": {
    "responses": [
      {
        "response_id": "resp-fake-gh-plan-close-1",
        "events": [
          {
            "item": {
              "type": "function_call",
              "call_id": "call_plan_close",
              "name": "shell_command",
              "arguments": "{\"command\": \"CODEX_GITHUB_TOKEN=synthetic-harness-token GH_WITH_ENV_TOKEN_GH=\\\"$(dirname \\\"$(dirname \\\"$CODE_EXEC_HARNESS_GH_STATE\\\")\\\")/bin/gh\\\" uv run \\\"$CODE_HOME/skills/github/scripts/gh-plan.py\\\" --repo cbusillo/codex-skills close 900 --comment-file close-comment.md\", \"timeout_ms\": 30000}"
            }
          }
        ]
      },
      {
        "response_id": "resp-fake-gh-plan-close-2",
        "events": [
          {
            "item": {
              "type": "function_call",
              "call_id": "wait_plan_close",
              "name": "wait",
              "arguments": "{\"call_id\": \"call_plan_close\", \"timeout_ms\": 600000}"
            }
          }
        ]
      },
      {
        "response_id": "resp-fake-gh-plan-close-3"
      }
    ]
  },
  "expect": {
    "returncode": 0,
    "gh_contains": [
      "api",
      "/user",
      "repos/cbusillo/codex-skills/issues/900/dependencies/blocked_by?per_page=100&page=1",
      "repos/cbusillo/codex-skills/issues/900/sub_issues?per_page=100&page=1",
      "/repos/cbusillo/codex-skills/issues/900/labels",
      "/repos/cbusillo/codex-skills/issues/900/labels/plan%3Aactive",
      "/repos/cbusillo/codex-skills/issues/900/comments",
      "--method PATCH",
      "/repos/cbusillo/codex-skills/issues/900"
    ],
    "responses_request_count": 3
  },
  "max_seconds": 45,
  "timeout_seconds": 120
}
