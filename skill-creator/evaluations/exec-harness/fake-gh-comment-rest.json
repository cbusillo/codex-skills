        "stdout": "[{\"id\":7,\"html_url\":\"https://github.com/owner/repo/issues/42#issuecomment-7\",\"user\":{\"login\":\"shiny-code-bot\"},\"created_at\":\"2026-07-16T12:00:00Z\"}]"
      },
      {
        "match": {
          "contains": ["api", "--method", "PATCH", "/repos/owner/repo/issues/comments/7"]
        },
        "stdout": "{\"id\":7,\"html_url\":\"https://github.com/owner/repo/issues/42#issuecomment-7\",\"user\":{\"login\":\"shiny-code-bot\"},\"updated_at\":\"2026-07-16T19:00:00Z\"}"
      }
    ]
  },
  "responses_api": {
    "responses": [
      {
        "response_id": "resp-fake-gh-comment-rest-1",
        "events": [
          {
            "item": {
              "type": "function_call",
              "call_id": "call_comment_rest",
              "name": "shell_command",
              "arguments": "{\"command\": \"GH_COMMENT_GH=\\\"$(dirname \\\"$(dirname \\\"$CODE_EXEC_HARNESS_GH_STATE\\\")\\\")/bin/gh\\\" \\\"$CODE_HOME/skills/github/scripts/gh-comment\\\" issue 42 --repo owner/repo --body-file comment.md --edit-last --create-if-none\", \"timeout_ms\": 30000}"
            }
          }
        ]
      },
      {
        "response_id": "resp-fake-gh-comment-rest-2",
        "events": [
          {
            "item": {
              "type": "function_call",
              "call_id": "wait_comment_rest",
              "name": "wait",
              "arguments": "{\"call_id\": \"call_comment_rest\", \"timeout_ms\": 600000}"
            }
          }
        ]
      },
      {
        "response_id": "resp-fake-gh-comment-rest-3"
      }
    ]
  },
  "expect": {
    "returncode": 0,
    "gh_contains": [
      "/user",
      "/repos/owner/repo/issues/42/comments?per_page=100&page=1",
      "--method PATCH",
      "/repos/owner/repo/issues/comments/7"
    ],
    "responses_request_count": 3
  },
  "max_seconds": 45,
  "timeout_seconds": 120
}
