{
  "name": "fake-gh-comment-rest",
  "model": "gpt-5.1-codex",
  "prompt": "Update the automation actor's latest comment on issue #42 using comment.md, creating one only if none exists. Use the GitHub comment helper.",
  "files": {
    "README.md": "# Fake gh REST comment fixture\n",
    "comment.md": "Updated evidence with `literal markdown`.\n"
  },
  "gh": {
    "repo": "owner/repo",
    "responses": [
      {
        "match": {
          "contains": ["api", "/user"]
        },
        "stdout": "{\"login\":\"shiny-code-bot\"}"
      },
      {
        "match": {
          "contains": ["api", "--method", "GET", "/repos/owner/repo/issues/42/comments?per_page=100&page=1"]
