{
  "defaultBranch": "main",
  "projectType": "codex-skills",
  "docs": {
    "index": "README.md",
    "githubSkill": "github/SKILL.md",
    "githubWorkflow": "github/references/repo-workflow.md",
    "executionEnvironment": "github/references/execution-environment.md",
    "githubConfigSchema": "github/references/config-schema.md",
    "launchplaneSkill": "launchplane/SKILL.md",
    "launchplaneContextContract": "launchplane/references/context-helper-contract.md",
    "launchplaneOperatorContract": "launchplane/references/operator-contract.md",
    "launchplaneOperatorConfigExample": "launchplane/references/launchplane-operator.local.example.json",
    "launchplaneWriteActionContract": "launchplane/references/write-action-helper-contract.md",
    "repoReadiness": "repo-readiness/SKILL.md",
    "workCloseout": "work-closeout/SKILL.md",
    "publicSafety": "launchplane/references/public-safety.md"
  },
  "qualityGate": {
    "inspection": {
      "ide": "PyCharm",
      "scopePreference": "changed_files"
    },
    "syntax": {
      "python": "uv run --python 3.12 python -m py_compile github/scripts/github_api.py github/scripts/github_comment.py github/scripts/github_issue.py github/scripts/github_read.py github/scripts/test_github_api.py github/scripts/test_github_ci_diagnose.py github/scripts/test_github_comment.py github/scripts/test_github_issue.py github/scripts/test_github_read.py github/scripts/validate-operation-matrix.py github/scripts/gh-plan.py github/scripts/gh-pr.py github/scripts/github-ci-diagnose.py github/scripts/reconcile-runtime-checkout.py launchplane/scripts/launchplane-context.py launchplane/scripts/launchplane-write-action.py launchplane/scripts/launchplane_safety.py launchplane/scripts/test_launchplane_helpers.py scripts/test_update_pep723_dependencies.py scripts/test_validate_execution_environment.py scripts/test_validate_github_actions_security.py scripts/update_pep723_dependencies.py scripts/validate_execution_environment.py scripts/validate_github_actions_security.py skill-creator/scripts/generate_openai_yaml.py skill-creator/scripts/init_skill.py skill-creator/scripts/quick_validate.py",
      "shell": "bash -n github/scripts/github-repo-snapshot.sh github/scripts/gh-with-env-token github/scripts/gh-issue github/scripts/gh-comment google-seo/scripts/google-cloud-inventory.sh scripts/validate-skills.sh"
    },
    "json": {
      "metadata": "jq empty .github/github.json"
    },
    "docsRequiredWhen": [
      "skill behavior changes",
      "script behavior changes",
      "config schema changes",
      "GitHub workflow changes",
      "public safety guidance changes"
    ]
  },
  "importantWorkflows": [
    "Validate Skills",
    "Launchplane Train Validation",
    "Update PEP 723 Dependencies"
  ],
  "qaLabels": [],
  "deployLabels": [],
  "healthUrls": [],
  "relatedRepos": [],
  "launchplane": {
    "enabled": true,
    "service": {
      "contextUrlEnv": "LAUNCHPLANE_CONTEXT_URL",
      "operatorUrlEnv": "LAUNCHPLANE_OPERATOR_URL",
      "localConfigExample": "launchplane/references/launchplane-operator.local.example.json"
    },
    "context": {
      "enabled": true,
      "helper": "launchplane/scripts/launchplane-context.py"
    },
    "operator": {
      "enabled": true,
      "helper": "launchplane/scripts/launchplane-write-action.py",
      "requiresPrivateConfig": true
    },
    "mergeTrain": {
      "enabled": true,
      "controller": true,
      "readyLabel": "ready-to-merge",
      "baseBranch": "main",
      "githubActionsRunner": {
        "repo": "cbusillo/launchplane",
        "workflow": "merge-train-runner.yml",
        "ref": "main",
        "runnerMode": "controller",
        "mutateDefault": false,
        "revisionEvidenceFields": {
          "runnerWorkflow": "workflow_run.head_sha",
          "candidate": "result.candidate.candidate_sha",
          "landing": "result.landing_plan.entries[].merge_commit_sha"
        }
      }
    }
  },
  "githubSignals": {
    "postMerge": {
      "waitForActions": true,
      "checkSecurityAndQuality": true
    },
    "capabilities": {
      "codeScanning": "unknown",
      "secretScanning": "unknown",
      "dependencyGraph": "unknown",
      "dependabotAlerts": "unknown",
      "securityAdvisories": "unknown"
    },
    "refreshWhen": [
      "repo visibility changes",
      "GitHub plan changes",
      "security settings change",
      "token permissions change"
    ]
  },
  "githubSettings": {
    "expected": {
      "deleteBranchOnMerge": true
    }
  },
  "cleanup": {
    "deleteMergedLocalBranches": true,
    "removeMergedCleanWorktrees": true,
    "commands": [
      {
        "name": "git status",
        "command": "git status --short --branch",
        "when": "routine",
        "description": "Confirm the checkout is clean before closeout."
      },
      {
        "name": "worktree list",
        "command": "git worktree list",
        "when": "routine",
        "description": "List linked worktrees so stale generated worktrees are visible."
      },
      {
        "name": "merged local branches",
        "command": "git branch --merged",
        "when": "routine",
        "description": "Surface local branches that Git can prove are merged."
      }
    ],
    "handoffArtifacts": {
      "temporaryGlobs": [
        "handoff*.md",
        "*-handoff.md"
      ],
      "durableSurface": "GitHub issue or PR comment"
    }
  },
  "metadataFreshness": {
    "updateWhen": [
      "docs routing changes",
      "validation gates change",
      "primary commands change",
      "important workflows change",
      "repo relationship changes",
      "Launchplane access routing changes",
      "cleanup policy changes",
      "ownership boundaries change",
      "execution environment policy changes"
    ]
  }
}
